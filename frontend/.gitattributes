# Auto detect text files and normalize line endings to LF in the repository
* text=auto

# Explicitly set line endings for common file types
*.js   text
*.jsx  text
*.json text
*.html text
*.css  text
*.md   text

# Binary files - do not modify line endings
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
